doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title Dashboard | ZonetoCode
    link(rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined")
    link(rel="stylesheet", href="/css/index.css")
  body
    nav.navbar#navbar
      strong(onclick="window.location.href='/'") ZonetoCode
      span.material-symbols-outlined.menu-icon#menuBtn(onclick="toggleMenu()") menu
      .nav-links#navLinks
        a(href="/profile").profile-link Profile
        a(href="/logout") Logout

    .container.dashboard-container
      .welcome-section
        h1 Welcome back, #{user ? user.firstname : 'Developer'}! 🚀
        p Here is what's happening with your projects today.

      // Statistics Overview
      .stats-grid
        .stat-card
          .stat-icon.blue: span.material-symbols-outlined description
          .stat-info
            h4 Total Projects
            p 12
        
        .stat-card
          .stat-icon.green: span.material-symbols-outlined task_alt
          .stat-info
            h4 Completed
            p 08
        
        .stat-card
          .stat-icon.orange: span.material-symbols-outlined pending_actions
          .stat-info
            h4 Pending
            p 04

      // Recent Activity Table
      .content-card
        .card-header
          h3 Recent Project Activity
          button.btn-view-all View All
        
        .table-wrapper
          table
            thead
              tr
                th Project Name
                th Date Created
                th Category
                th Status
            tbody
              tr
                td MERN Authentication
                td Mar 24, 2026
                td Web App
                td: span.status-pill.status-active Active
              tr
                td Responsive Portfolio
                td Feb 12, 2026
                td Design
                td: span.status-pill.status-active Active
              tr
                td SQL Database Script
                td Jan 05, 2026
                td Backend
                td: span.status-pill.status-active Active

    footer
      p © 2026 ZonetoCode. Full-Stack Engineering Trainee Dashboard.

    script(src="/js/script.js")