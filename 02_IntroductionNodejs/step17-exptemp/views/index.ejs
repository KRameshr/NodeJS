    <!-- MARQUEE -->
    <div class="marquee-section">
      <div class="marquee-track">
        <div class="marquee-item">Lightning Fast</div>
        <div class="marquee-item">Developer First</div>
        <div class="marquee-item">Zero Config</div>
        <div class="marquee-item">Enterprise Ready</div>
        <div class="marquee-item">Open Source Friendly</div>
