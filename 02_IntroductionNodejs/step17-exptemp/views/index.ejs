    <!-- FEATURES -->
    <section id="features">
      <div class="section">
        <div class="section-label reveal">Why NovaSpark</div>
        <h2 class="section-title reveal">
          Everything you need.<br />Nothing you don't.
        </h2>
        <p class="section-sub reveal">
          We cut the complexity so your team can focus on what actually matters
          — building remarkable products.
        </p>

        <div class="features-grid reveal">
          <div class="feature-card">
            <div class="feature-icon">⚡</div>
            <h3>Instant Deployment</h3>
            <p>
              Push code and go live in seconds. No config files, no YAML
              nightmares. Just ship.
            </p>
          </div>
          <div class="feature-card">
            <div class="feature-icon">🔐</div>
            <h3>Security by Default</h3>
            <p>
              End-to-end encryption, SOC2 compliant, and automatic security
              patches. Sleep well.
            </p>
          </div>
          <div class="feature-card">
            <div class="feature-icon">📊</div>
            <h3>Real-time Analytics</h3>
            <p>
              See exactly how your product performs. Every metric, every user,
              every moment.
            </p>
          </div>
          <div class="feature-card">
            <div class="feature-icon">🌐</div>
            <h3>Global Edge Network</h3>
            <p>
              Serve users from 200+ locations worldwide. Under 50ms latency,
              guaranteed.
            </p>
          </div>
          <div class="feature-card">
            <div class="feature-icon">🤖</div>
            <h3>AI-Powered Scaling</h3>
            <p>
              Predictive autoscaling that handles traffic spikes before they
              become problems.
            </p>
          </div>
          <div class="feature-card">
            <div class="feature-icon">🔗</div>
            <h3>140+ Integrations</h3>
            <p>
              Connect your favorite tools in one click. Slack, GitHub, Stripe,
              and many more.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- HOW IT WORKS -->
    <div id="how" class="steps-section">
      <div class="steps-inner">
        <div class="section-label reveal">How it works</div>
        <h2 class="section-title reveal">
          From idea to production<br />in four steps
        </h2>
        <div class="steps-grid reveal">
          <div class="step-card">
            <div class="step-num">01</div>
            <h4>Connect your repo</h4>
            <p>Link GitHub, GitLab, or Bitbucket in under 60 seconds.</p>
          </div>
          <div class="step-card">
            <div class="step-num">02</div>
            <h4>Configure once</h4>
            <p>Set your environment, domains, and secrets. Never again.</p>
          </div>
          <div class="step-card">
            <div class="step-num">03</div>
            <h4>Push & deploy</h4>
            <p>Every git push triggers a smart build pipeline automatically.</p>
          </div>
          <div class="step-card">
            <div class="step-num">04</div>
            <h4>Scale with ease</h4>
            <p>Handle millions of users without touching infrastructure.</p>
          </div>
        </div>
      </div>
    </div>

    <!-- CTA -->
    <div class="cta-section">
      <div class="cta-box reveal">
        <h2>Ready to build<br />something great?</h2>
