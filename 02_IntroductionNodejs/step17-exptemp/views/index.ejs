    <!-- HERO -->
    <section class="hero">
      <div class="hero-bg"></div>
      <div class="hero-grid"></div>

      <div class="badge">
        <span class="badge-dot"></span>
        Now in public beta — Join 12,000+ builders
      </div>

      <h1>Build products<br />that feel <em>alive</em></h1>

      <p>
        NovaSpark gives your team the infrastructure to ship faster, scale
        smarter, and deliver experiences users actually remember.
      </p>

      <div class="hero-actions">
        <a href="#" class="btn-primary">Start building free →</a>
        <a href="#how" class="btn-ghost">
          <svg
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <circle cx="12" cy="12" r="10" />
            <polygon points="10 8 16 12 10 16 10 8" />
          </svg>
          Watch demo
        </a>
      </div>

      <div class="hero-stats">
        <div class="stat-item">
          <span class="stat-num">12<span>k+</span></span>
          <div class="stat-label">Active builders</div>
        </div>
        <div class="stat-item">
          <span class="stat-num">99<span>.9%</span></span>
          <div class="stat-label">Uptime SLA</div>
        </div>
        <div class="stat-item">
          <span class="stat-num">3<span>x</span></span>
          <div class="stat-label">Faster shipping</div>
        </div>
        <div class="stat-item">
          <span class="stat-num">140<span>+</span></span>
          <div class="stat-label">Integrations</div>
        </div>
      </div>
