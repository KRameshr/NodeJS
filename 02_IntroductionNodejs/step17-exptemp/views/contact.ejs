<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Contact — NovaSpark</title>
    <link
      href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/index.css" />
  </head>
  <body>
    <!-- NAV -->
    <nav>
      <div class="logo">Nova<span>Spark</span> ✦</div>
      <ul class="nav-links">
        <li><a href="/">Home</a></li>
        <li><a href="/about">About</a></li>
        <li><a href="/contact">Contact</a></li>
        <li><a href="#" class="nav-cta">Get Started →</a></li>
      </ul>
    </nav>

    <!-- CONTACT HERO -->
    <section class="contact-hero">
      <div class="badge">
        <span class="badge-dot"></span>
        Get In Touch
      </div>
      <h1>We'd love to<br /><em>hear from you</em></h1>
      <p>
        Have a question, idea, or just want to say hello? Our team replies
        within 24 hours.
      </p>
    </section>

    <!-- CONTACT SECTION -->
    <section class="contact-section">
      <!-- LEFT INFO -->
      <div class="contact-info">
        <div class="info-card">
          <span class="info-icon">📧</span>
          <div>
            <h4>Email Us</h4>
            <p>hello@novaspark.io</p>
          </div>
        </div>

        <div class="info-card">
          <span class="info-icon">💬</span>
          <div>
            <h4>Live Chat</h4>
            <p>Available Mon–Fri, 9am–6pm IST</p>
          </div>
        </div>

        <div class="info-card">
          <span class="info-icon">📍</span>
          <div>
            <h4>Office</h4>
            <p>Bengaluru, India 🇮🇳</p>
          </div>
        </div>

        <div class="info-card">
          <span class="info-icon">🐦</span>
          <div>
            <h4>Twitter / X</h4>
            <p>@novaspark</p>
          </div>
        </div>

        <div class="social-links">
          <a href="#" class="social-btn">GitHub</a>
          <a href="#" class="social-btn">LinkedIn</a>
          <a href="#" class="social-btn">Twitter</a>
        </div>
      </div>

      <!-- RIGHT FORM -->
      <div class="contact-form-box">
        <h3>Send a message</h3>
        <p class="form-sub">
          Fill in the form and we'll get back to you shortly.
        </p>

        <form class="contact-form" action="/contact" method="POST">
          <div class="form-row">
            <div class="form-group">
              <label for="name">Your Name</label>
              <input
                type="text"
                id="name"
                name="name"
                placeholder="John Doe"
                required
              />
            </div>
            <div class="form-group">
              <label for="email">Email Address</label>
              <input
                type="email"
                id="email"
                name="email"
                placeholder="john@email.com"
                required
              />
            </div>
          </div>

          <div class="form-group">
            <label for="subject">Subject</label>
            <input
              type="text"
              id="subject"
              name="subject"
              placeholder="How can we help?"
              required
            />
          </div>

          <div class="form-group">
            <label for="type">Enquiry Type</label>
            <select id="type" name="type">
              <option value="general">General Question</option>
              <option value="support">Technical Support</option>
              <option value="sales">Sales & Pricing</option>
              <option value="partnership">Partnership</option>
            </select>
          </div>

          <div class="form-group">
            <label for="message">Message</label>
            <textarea
              id="message"
              name="message"
              rows="5"
              placeholder="Tell us more..."
              required
            ></textarea>
          </div>

          <button type="submit" class="btn-primary submit-btn">
            Send Message →
          </button>
        </form>
      </div>
    </section>

    <!-- FOOTER -->
    <footer>
      <div class="footer-logo">Nova<span>Spark</span></div>
      <ul class="footer-links">
        <li><a href="/">Home</a></li>
        <li><a href="/about">About</a></li>
        <li><a href="/contact">Contact</a></li>
      </ul>
      <div class="footer-copy">© 2026 NovaSpark. All rights reserved.</div>
    </footer>
  </body>
</html>
