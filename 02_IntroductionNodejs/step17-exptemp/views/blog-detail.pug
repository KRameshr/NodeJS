doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title #{post.title} — NovaSpark
    link(href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet")
    link(rel="stylesheet" href="/index.css")
  body

    //- ── NAV ──────────────────────────────────
    nav
      .logo Nova
        span Spark
        |  ✦
      ul.nav-links
        li: a(href="/") Home
        li: a(href="/about") About
        li: a(href="/features") Features
        li: a(href="/blog") Blog
        li: a(href="/contact" class="nav-cta") Contact →

    //- ── POST PAGE ────────────────────────────
    .post-page

      //- Back button
      a.back-btn(href="/blog") ← Back to Blog

      //- Category
      p.post-category ✦ #{post.category}

      //- Title
      h1 #{post.title}

      //- Slug
      p.post-slug 🔗 /blog/#{post.slug}

      //- Meta info
      .post-meta
        span 👤 #{post.author}
        span 📅 #{post.date}
        span ⏱ #{post.read} read
        span
          | ID: #
          | #{post.id}

      //- Content
      p.post-content #{post.content}

      //- Related posts
      .related-section
        h3 More Articles
        .related-list
          each p in posts.filter(p => p.slug !== post.slug)
            a.related-link(href=`/blog/${p.slug}`)
              span #{p.title}
              .related-right
                span.related-read #{p.read}
                span.related-cat #{p.category}

    //- ── FOOTER ───────────────────────────────
    footer
      .footer-logo Nova
        span Spark
      ul.footer-links
        li: a(href="/") Home
        li: a(href="/blog") Blog
        li: a(href="/contact") Contact
      .footer-copy © 2026 NovaSpark.