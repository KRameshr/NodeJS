<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>404 — NovaSpark</title>
    <link
      href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/index.css" />
  </head>
  <body>
    <!-- NAV -->
    <nav>
      <div class="logo">Nova<span>Spark</span> ✦</div>
      <ul class="nav-links">
        <li><a href="/">Home</a></li>
        <li><a href="/about">About</a></li>
        <li><a href="/contact">Contact</a></li>
        <li><a href="#" class="nav-cta">Get Started →</a></li>
      </ul>
    </nav>

    <!-- 404 SECTION -->
    <section class="notfound-section">
      <div class="notfound-bg"></div>
      <div class="notfound-grid"></div>

      <div class="notfound-code">404</div>

      <div class="badge">
        <span class="badge-dot"></span>
        Page Not Found
      </div>

      <h1>Oops! You're lost<br />in <em>deep space</em></h1>

      <p>
        The page you're looking for doesn't exist, was moved, or maybe never
        existed. Let's get you back on track.
      </p>

      <div class="notfound-actions">
        <a href="/" class="btn-primary">← Back to Home</a>
        <a href="/contact" class="btn-ghost">Contact Support</a>
      </div>

      <!-- FLOATING STARS -->
      <div class="stars">
        <span class="star s1">✦</span>
        <span class="star s2">✦</span>
        <span class="star s3">✦</span>
        <span class="star s4">✦</span>
        <span class="star s5">✦</span>
      </div>
    </section>

    <!-- FOOTER -->
    <footer>
      <div class="footer-logo">Nova<span>Spark</span></div>
      <ul class="footer-links">
        <li><a href="/">Home</a></li>
        <li><a href="/about">About</a></li>
        <li><a href="/contact">Contact</a></li>
      </ul>
      <div class="footer-copy">© 2026 NovaSpark. All rights reserved.</div>
    </footer>
  </body>
</html>
