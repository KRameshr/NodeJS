<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>About — NovaSpark</title>
    <link
      href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/index.css" />
  </head>
  <body>
    <!-- NAV -->
    <nav>
      <div class="logo">Nova<span>Spark</span> ✦</div>
      <ul class="nav-links">
        <li><a href="/">Home</a></li>
        <li><a href="/about">About</a></li>
        <li><a href="/contact">Contact</a></li>
        <li><a href="#" class="nav-cta">Get Started →</a></li>
      </ul>
    </nav>

    <!-- ABOUT HERO -->
    <section class="about-hero">
      <div class="badge">
        <span class="badge-dot"></span>
        Our Story
      </div>
      <h1>We build tools for<br /><em>bold</em> builders</h1>
      <p>
        NovaSpark was founded in 2023 by developers who were tired of slow,
        bloated infrastructure. We believe shipping should be joyful.
      </p>
    </section>

    <!-- TEAM -->
    <section class="about-section">
      <div class="section-label">The Team</div>
      <h2 class="section-title">People behind the spark</h2>

      <div class="team-grid">
        <div class="team-card">
          <div class="team-avatar">AK</div>
          <h3>Arjun Kumar</h3>
          <p class="team-role">Co-Founder & CEO</p>
          <p class="team-bio">
            Previously at Google. Loves fast code and strong coffee.
          </p>
        </div>
        <div class="team-card">
          <div class="team-avatar">SR</div>
          <h3>Sara Ramos</h3>
          <p class="team-role">Co-Founder & CTO</p>
          <p class="team-bio">
            Built infra at Netflix. Obsessed with zero-downtime deploys.
          </p>
        </div>
        <div class="team-card">
          <div class="team-avatar">TN</div>
          <h3>Tom Nguyen</h3>
          <p class="team-role">Head of Design</p>
          <p class="team-bio">
            Crafts interfaces that users remember. Ex-Figma designer.
          </p>
        </div>
      </div>
    </section>

    <!-- VALUES -->
    <section class="values-section">
      <div class="section-label">Our Values</div>
      <h2 class="section-title">What we stand for</h2>

      <div class="values-grid">
        <div class="value-card">
          <span class="value-icon">⚡</span>
          <h4>Speed First</h4>
          <p>
            Every decision we make optimizes for speed — for us and for you.
          </p>
        </div>
        <div class="value-card">
          <span class="value-icon">🔓</span>
          <h4>Radical Transparency</h4>
          <p>
            No hidden fees, no lock-in. We say what we mean and ship what we
            promise.
          </p>
        </div>
        <div class="value-card">
          <span class="value-icon">🌍</span>
          <h4>Builder Community</h4>
          <p>We grow when our users grow. Their success is our north star.</p>
        </div>
        <div class="value-card">
          <span class="value-icon">🔬</span>
          <h4>Always Improving</h4>
          <p>
            We ship daily, learn constantly, and never settle for good enough.
          </p>
        </div>
      </div>
    </section>

    <!-- FOOTER -->
    <footer>
      <div class="footer-logo">Nova<span>Spark</span></div>
      <ul class="footer-links">
        <li><a href="/">Home</a></li>
        <li><a href="/about">About</a></li>
        <li><a href="#">Blog</a></li>
        <li><a href="#">Careers</a></li>
      </ul>
      <div class="footer-copy">© 2026 NovaSpark. All rights reserved.</div>
    </footer>
  </body>
</html>
